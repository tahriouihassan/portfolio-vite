---
import ActionButton from "./ActionButton.astro";
import Icon from "./Icon.astro";
import { CONTACT } from "../consts";
import { getLocale, ui, localizePath } from "../i18n";

const locale = getLocale(Astro.url);
const t = ui[locale].hero;
---

<section class="flex flex-col gap-8">
  <p class="font-theme_bold text-sm uppercase tracking-widest text-link_text_hover">
    {t.eyebrow}
  </p>

  <h1
    class="text-3xl font-theme_bold leading-tight text-head_text sm:text-4xl slg:text-5xl slg:leading-tight"
  >
    {t.h1}
  </h1>

  <div class="text-content max-w-3xl">
    <p class="text-sm leading-relaxed slg:text-lg lg:leading-loose" set:html={t.p1} />
    <p class="text-sm leading-relaxed slg:text-lg lg:leading-loose" set:html={t.p2} />
  </div>

  <div class="flex flex-wrap items-center gap-3">
    <ActionButton link={CONTACT.bookingUrl} variant="primary">
      <Icon name="calendar" size={18} />{t.ctaPrimary}
    </ActionButton>
    <ActionButton link={localizePath("/projects", locale)}>
      {t.ctaSecondary} <Icon name="arrow-right" size={18} />
    </ActionButton>
  </div>

  <dl class="mt-2 grid grid-cols-1 gap-4 border-t border-border_sm pt-6 sm:grid-cols-3">
    {
      t.stats.map((s) => (
        <div class="flex items-baseline gap-3 sm:flex-col sm:items-start sm:gap-1">
          <dt class="font-theme_bold text-lg text-head_text sm:text-xl slg:text-2xl">{s.value}</dt>
          <dd class="text-xs text-p_text slg:text-sm">{s.label}</dd>
        </div>
      ))
    }
  </dl>
</section>
