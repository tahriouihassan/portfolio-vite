---
import ActionButton from "./ActionButton.astro";
import Icon from "./Icon.astro";
import { CONTACT } from "../consts";
import { getLocale, ui, localizePath } from "../i18n";

const locale = getLocale(Astro.url);
const t = ui[locale].hero;
---

<section class="relative flex flex-col gap-8">
  <!-- Subtle brand glows behind the hero -->
  <div
    class="pointer-events-none absolute -left-40 -top-44 h-[420px] w-[420px] rounded-full opacity-70 blur-2xl"
    style="background: radial-gradient(closest-side, rgba(99,102,241,0.16), transparent);"
    aria-hidden="true"
  >
  </div>
  <div
    class="pointer-events-none absolute -right-32 top-24 h-[360px] w-[360px] rounded-full opacity-60 blur-2xl"
    style="background: radial-gradient(closest-side, rgba(217,70,239,0.10), transparent);"
    aria-hidden="true"
  >
  </div>

  <div class="flex flex-wrap items-center gap-4">
    <span
      class="inline-flex w-fit items-center gap-2 rounded-full border border-border_sm bg-item_back px-3 py-1.5 text-xs text-action_text"
    >
      <span class="relative flex h-2 w-2">
        <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-[#4ade80] opacity-60"></span>
        <span class="relative inline-flex h-2 w-2 rounded-full bg-[#4ade80]"></span>
      </span>
      {t.badge}
    </span>
  </div>

  <p class="font-theme_bold text-sm uppercase tracking-widest text-link_text_hover">
    {t.eyebrow}
  </p>

  <h1
    class="text-3xl font-theme_bold leading-tight text-head_text sm:text-4xl slg:text-5xl slg:leading-tight"
  >
    {t.h1}
  </h1>

  <div class="text-content max-w-3xl">
    <p class="text-sm leading-relaxed slg:text-lg lg:leading-loose" set:html={t.p1} />
    <p class="text-sm leading-relaxed slg:text-lg lg:leading-loose" set:html={t.p2} />
  </div>

  <div class="flex flex-wrap items-center gap-3">
    <ActionButton link={CONTACT.bookingUrl} variant="primary">
      <Icon name="calendar" size={18} />{t.ctaPrimary}
    </ActionButton>
    <ActionButton link={localizePath("/projects", locale)}>
      {t.ctaSecondary} <Icon name="arrow-right" size={18} />
    </ActionButton>
  </div>

  <dl class="mt-2 grid grid-cols-1 gap-4 border-t border-border_sm pt-6 sm:grid-cols-3">
    {
      t.stats.map((s) => (
        <div class="flex items-baseline gap-3 sm:flex-col sm:items-start sm:gap-1">
          <dt class="font-theme_bold text-lg text-head_text sm:text-xl slg:text-2xl">{s.value}</dt>
          <dd class="text-xs text-p_text slg:text-sm">{s.label}</dd>
        </div>
      ))
    }
  </dl>
</section>
