---
import Icon from "./Icon.astro";
interface Props {
  title: string;
  link: string;
  icon: string;
}
const { title, link, icon } = Astro.props;
---

<a
  href={link}
  title={title}
  aria-label={title}
  target="_blank"
  rel="noopener noreferrer"
  class="inline-flex rounded-md p-2 text-p_text transition-all hover:bg-border_sm hover:text-head_text"
>
  <Icon name={icon} size={26} />
</a>
