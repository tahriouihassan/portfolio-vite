---
import { NAV, SITE } from "../consts";
const path = Astro.url.pathname.replace(/\/+$/, "") || "/";
const isActive = (href: string) =>
  href === "/" ? path === "/" : path === href || path.startsWith(href + "/");
---

<nav
  class="fixed bottom-0 z-40 flex w-full items-center justify-between border-b border-border_sm bg-navbar_back px-3 py-3 backdrop-blur-sm sm:bottom-auto sm:top-0 sm:px-6 lg:py-4"
>
  <div class="absolute left-0 top-0 h-[1px] w-full bg-topbar lg:h-1"></div>

  <a
    href="/"
    class="select-none font-logo text-3xl font-normal slg:font-semibold lg:text-4xl"
    aria-label={`${SITE.name} home`}
  >
    {SITE.logo}
  </a>

  <div class="flex items-center gap-0.5 text-sm sm:gap-2 lg:text-base">
    {
      NAV.map((item) => (
        <a
          href={item.href}
          aria-current={isActive(item.href) ? "page" : undefined}
          class="rounded-md px-2.5 py-1.5 font-theme_bold transition-all hover:bg-action_back sm:px-4 sm:py-2"
        >
          {item.label}
        </a>
      ))
    }
    <a
      href="/contact"
      aria-current={isActive("/contact") ? "page" : undefined}
      class="ml-1 hidden rounded-md border border-accent bg-accent px-4 py-2 font-theme_bold text-white transition-colors hover:brightness-110 sm:inline-block"
    >
      Let's talk
    </a>
  </div>
</nav>
