---
import BaseLayout from "../layouts/BaseLayout.astro";
import ContactForm from "../components/ContactForm.astro";
import Divider from "../components/Divider.astro";
import Icon from "../components/Icon.astro";
import SocialIcon from "../components/SocialIcon.astro";
import { SITE, CONTACT, SOCIALS } from "../consts";
import { ui } from "../i18n";

const faq = ui.en.faq;
const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faq.items.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---

<BaseLayout
  title="Contact"
  description="Start a project with Hassan Tahrioui. Book a free intro call, send a message or reach out on WhatsApp about your web platform, SaaS or e-commerce build."
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(faqLd)} />
  <div class="flex flex-col gap-14">
    <section class="flex flex-col gap-5">
      <h1 class="font-theme_bold text-3xl text-head_text sm:text-4xl slg:text-5xl">
        Let's build it<span class="text-link_text_hover">.</span>
      </h1>
      <p class="max-w-2xl text-base slg:text-lg">
        Tell me what you're working on: a new platform, a rescue project, or a specific feature.
        I'll reply with how I'd approach it and whether I'm the right fit.
      </p>
    </section>

    <div class="grid grid-cols-1 gap-10 slg:grid-cols-[1.4fr_1fr]">
      <div class="rounded-lg border border-border_sm bg-item_back p-6 slg:p-8">
        <ContactForm />
      </div>

      <aside class="flex flex-col gap-6">
        <a
          href={CONTACT.bookingUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-3 rounded-md border border-accent bg-accent px-5 py-4 font-theme_bold text-white transition hover:brightness-110"
        >
          <Icon name="calendar" size={20} />
          Book a free intro call
        </a>

        <a
          href={`https://wa.me/${CONTACT.whatsapp}`}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-3 rounded-md border border-border_sm bg-action_back px-5 py-4 text-action_text transition-colors hover:bg-item_hover_back"
        >
          <Icon name="whatsapp" size={20} />
          Message me on WhatsApp
        </a>

        <a
          href={`mailto:${SITE.email}`}
          class="flex items-center gap-3 rounded-md border border-border_sm bg-action_back px-5 py-4 text-action_text transition-colors hover:bg-item_hover_back"
        >
          <Icon name="mail" size={20} />
          {SITE.email}
        </a>

        <div class="flex flex-col gap-3 rounded-md border border-border_sm p-5 text-sm">
          <span class="font-theme_bold text-head_text">Availability</span>
          <p>{SITE.location}</p>
          <p>Available part-time. Currently taking on a limited number of freelance projects.</p>
        </div>

        <div class="flex flex-col gap-2">
          <span class="text-sm font-theme_bold text-head_text">Elsewhere</span>
          <div class="flex gap-1">
            {SOCIALS.map((s) => <SocialIcon title={s.name} link={s.url} icon={s.icon} />)}
          </div>
        </div>
      </aside>
    </div>

    <Divider />

    <section class="flex flex-col gap-8">
      <h2 class="font-theme_bold text-2xl text-head_text slg:text-4xl">
        {faq.heading}<span class="text-link_text_hover">.</span>
      </h2>
      <div class="grid grid-cols-1 gap-5 slg:grid-cols-2">
        {
          faq.items.map((f) => (
            <div class="flex flex-col gap-2 rounded-md border border-border_sm bg-item_back p-6">
              <h3 class="font-theme_bold text-head_text">{f.q}</h3>
              <p class="text-sm leading-relaxed">{f.a}</p>
            </div>
          ))
        }
      </div>
    </section>
  </div>
</BaseLayout>
