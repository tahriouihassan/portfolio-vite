---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ServiceCard from "../../components/ServiceCard.astro";
import Divider from "../../components/Divider.astro";
import CtaSection from "../../components/CtaSection.astro";
import { ui, resolveService } from "../../i18n";

const services = (await getCollection("services")).sort(
  (a, b) => a.data.order - b.data.order
);
const engagements = ui.fr.engagements;

const process = [
  {
    step: "01",
    title: "Comprendre l'objectif",
    body: "Je pars du résultat commercial, pas du ticket. Ce qui doit se passer, pour qui, et pourquoi c'est important.",
  },
  {
    step: "02",
    title: "Concevoir le workflow",
    body: "UX, modèle de données et architecture ensemble, pour un produit utilisable, scalable et sain à maintenir.",
  },
  {
    step: "03",
    title: "Tout construire",
    body: "Frontend, backend, paiements, intégrations et infrastructure. Une seule personne, un système cohérent.",
  },
  {
    step: "04",
    title: "Livrer & assurer le suivi",
    body: "Déploiement, monitoring et astreinte. Je corrige les problèmes de production que la plupart des freelances vous laissent.",
  },
];

const differentiators = [
  "Je comprends les produits dans leur ensemble : design, frontend, backend, infra, paiements, SEO et exploitation.",
  "J'ai livré des plateformes commerciales qui vendent des billets, encaissent des paiements et gèrent de vraies réservations.",
  "J'assume la responsabilité de la production. Serveurs, bases de données, files, tracking et incidents compris.",
  "J'allie ingénierie et vision produit : UX, conversion, SEO, pricing et onboarding.",
  "J'ai dirigé des développements et coordonné d'autres développeurs et des interlocuteurs non techniques.",
  "Je construis des systèmes réutilisables et multi-marques, en marque blanche avec une personnalisation maîtrisée.",
];
---

<BaseLayout
  title="Services"
  description="Développement full-stack freelance : plateformes SaaS, e-commerce et paiements, API et automatisation, fonctionnalités IA, DevOps et SEO technique, construits et suivis de bout en bout."
>
  <div class="flex flex-col gap-16 slg:gap-24">
    <section class="flex flex-col gap-5">
      <h1 class="font-theme_bold text-3xl text-head_text sm:text-4xl slg:text-5xl">
        Services<span class="text-link_text_hover">.</span>
      </h1>
      <p class="max-w-2xl text-base slg:text-lg">
        J'aide les fondateurs et les équipes à livrer des produits web générateurs de revenus, et je
        reste impliqué après le lancement. Voici ce que je prends en charge.
      </p>
    </section>

    <section class="grid grid-cols-1 gap-5 md:grid-cols-2">
      {services.map((s) => <ServiceCard {...resolveService(s.data, "fr")} />)}
    </section>

    <Divider />

    <section class="flex flex-col gap-8">
      <div class="flex flex-col gap-3">
        <h2 class="font-theme_bold text-2xl text-head_text slg:text-4xl">
          {engagements.heading}<span class="text-link_text_hover">.</span>
        </h2>
        <p class="max-w-2xl text-sm slg:text-lg">{engagements.sub}</p>
      </div>
      <div class="grid grid-cols-1 gap-5 slg:grid-cols-3">
        {
          engagements.items.map((m) => (
            <div class="relative flex flex-col gap-3 overflow-hidden rounded-md border border-border_sm bg-item_back p-6">
              <div class="absolute inset-x-0 top-0 h-[2px] bg-topbar opacity-60" />
              <h3 class="font-theme_bold text-lg text-head_text">{m.title}</h3>
              {m.price && <span class="w-fit bg-btn_back px-2 py-1 text-xs text-btn_text">{m.price}</span>}
              <p class="text-sm leading-relaxed">{m.body}</p>
            </div>
          ))
        }
      </div>
    </section>

    <Divider />

    <section class="flex flex-col gap-8">
      <h2 class="font-theme_bold text-2xl text-head_text slg:text-4xl">
        Ma façon de travailler<span class="text-link_text_hover">.</span>
      </h2>
      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 slg:grid-cols-4">
        {
          process.map((p) => (
            <div class="flex flex-col gap-3 rounded-md border border-border_sm bg-item_back p-6">
              <span class="font-theme_bold text-2xl text-link_text_hover">{p.step}</span>
              <h3 class="font-theme_bold text-head_text">{p.title}</h3>
              <p class="text-sm">{p.body}</p>
            </div>
          ))
        }
      </div>
    </section>

    <Divider />

    <section class="flex flex-col gap-8">
      <h2 class="font-theme_bold text-2xl text-head_text slg:text-4xl">
        Pourquoi travailler avec moi<span class="text-link_text_hover">.</span>
      </h2>
      <ul class="grid grid-cols-1 gap-x-8 gap-y-4 slg:grid-cols-2">
        {
          differentiators.map((d) => (
            <li class="flex items-start gap-3 text-sm slg:text-base">
              <span class="mt-1.5 h-2 w-2 shrink-0 rounded-full bg-topbar" />
              <span>{d}</span>
            </li>
          ))
        }
      </ul>
    </section>

    <CtaSection heading="Cadrons votre projet" />
  </div>
</BaseLayout>
